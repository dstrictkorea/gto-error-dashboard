# ══════════════════════════════════════════════
#  G-ATIS v4.0 — Environment Variables
# ══════════════════════════════════════════════

# Azure AD Authentication (required)
AZURE_TENANT=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_SECRET=your-azure-client-secret

# SharePoint Drive (required)
SP_DRIVE_ID=your-sharepoint-drive-id
SP_FILE_ID=your-sharepoint-file-id

# SharePoint Sheet Names (optional — defaults shown)
# SP_SHEET_HQ=Table_HQ
# SP_SHEET_HISTORY=Past_History
# SP_SHEET_ASSETS=Asset_List
# SP_SHEET_SUMMARY=Table_Summary

# App Security (required — change from default!)
APP_PASSWORD=your-secure-password

# AI API Keys (at least 1 required for AI features)
GEMINI_KEY=your-google-gemini-api-key
GROQ_KEY=your-groq-api-key
MISTRAL_KEY=your-mistral-api-key

# Server
PORT=3000
# NODE_ENV=production

# CORS (optional — defaults to same-origin)
# CORS_ORIGIN=https://your-domain.com
