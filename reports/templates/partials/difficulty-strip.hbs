{{!-- difficulty-strip.hbs — Compact segmented strip (reported difficulty)
  Uses root context: difficultyDistribution[], diffSummary
  Each item: { name, count, valLabel, color, segW }
--}}
{{#if difficultyDistribution.length}}
<div class="dstrip">
  <div class="dstrip__track">
    {{#each difficultyDistribution}}
    <div class="dstrip__seg" style="width:{{segW}}%;background:{{color}}" title="{{name}}: {{valLabel}}"></div>
    {{/each}}
  </div>
  <div class="dstrip__legend">
    {{#each difficultyDistribution}}
    <div class="dstrip__row">
      <span class="dstrip__dot" style="background:{{color}}"></span>
      <span class="dstrip__lbl">{{name}}</span>
      <span class="dstrip__val">{{valLabel}}</span>
    </div>
    {{/each}}
  </div>
  {{#if diffSummary}}<p class="chart-summary">{{diffSummary}}</p>{{/if}}
</div>
{{else}}
<p class="hbar__empty">—</p>
{{/if}}
