{{!-- zone-matrix.hbs — Zone × Category matrix
  Uses root: zoneCategoryMatrix.{categories[{name,color}], rows[{zone, cells[{count,intensityClass}]}]}
  Categories are now objects with .name and .color for consistent coloring.
--}}
{{#if zoneCategoryMatrix.rows.length}}
<div class="matrix-wrap">
  <table class="matrix-table">
    <thead>
      <tr>
        <th></th>
        {{#each zoneCategoryMatrix.categories}}
        <th title="{{this.name}}" style="color:{{this.color}}">{{this.name}}</th>
        {{/each}}
      </tr>
    </thead>
    <tbody>
      {{#each zoneCategoryMatrix.rows}}
      <tr>
        <td class="row-label">{{zone}}</td>
        {{#each cells}}
        <td class="matrix-cell{{#if intensityClass}} matrix-cell--{{intensityClass}}{{/if}}">
          {{#if count}}{{count}}{{else}}–{{/if}}
        </td>
        {{/each}}
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{#if @root.matrixSummary}}<p class="chart-summary">{{@root.matrixSummary}}</p>{{/if}}
</div>
{{else}}
<p class="hbar__empty">—</p>
{{/if}}
