{{!-- action-pill.hbs — Segmented pill bar (action type distribution)
  Uses root context: actionTypeSorted[], actionSummary
  Each item: { name, count, valLabel, color, segW }
--}}
{{#if actionTypeSorted.length}}
<div class="apill">
  <div class="apill__track">
    {{#each actionTypeSorted}}
    <div class="apill__seg" style="width:{{segW}}%;background:{{color}}" title="{{name}}: {{valLabel}}"></div>
    {{/each}}
  </div>
  <div class="apill__legend">
    {{#each actionTypeSorted}}
    <div class="apill__row">
      <span class="apill__dot" style="background:{{color}}"></span>
      <span class="apill__lbl">{{name}}</span>
      <span class="apill__val">{{valLabel}}</span>
    </div>
    {{/each}}
  </div>
  {{#if actionSummary}}<p class="chart-summary">{{actionSummary}}</p>{{/if}}
</div>
{{else}}
<p class="hbar__empty">—</p>
{{/if}}
