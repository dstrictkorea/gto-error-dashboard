{{!-- trend-daily.hbs — Daily line chart
  Uses root context: dailyTrend[], svgPolylinePoints, svgAreaPoints, svgAvgY,
                     dailyTrendFirst, dailyTrendLast, dailyTrendPeak, dailyTrendLatest,
                     trendMaxCount, labels.casesUnit
--}}
{{#if dailyTrend.length}}
<div class="trend-with-yaxis">
  {{!-- Y-axis ──────────────────────────────── --}}
  <div class="trend-yaxis">
    <span class="trend-yaxis-max">{{trendMaxCount}}</span>
    <span class="trend-yaxis-unit">{{labels.casesUnit}}</span>
    <span class="trend-yaxis-zero">0</span>
  </div>
  {{!-- Chart area ──────────────────────────── --}}
  <div class="trend-wrap">
    <div class="trend-line-area">
      <svg class="trend-line-svg" viewBox="0 0 100 44" preserveAspectRatio="none">
        {{!-- Filled area under the line --}}
        {{#if svgAreaPoints}}
        <polygon class="trend-svg-area" points="{{svgAreaPoints}}" />
        {{/if}}
        {{!-- Average baseline --}}
        {{#if svgAvgY}}
        <line class="trend-svg-avg" x1="0" y1="{{svgAvgY}}" x2="100" y2="{{svgAvgY}}" />
        {{/if}}
        {{!-- Main line --}}
        {{#if svgPolylinePoints}}
        <polyline class="trend-svg-line" points="{{svgPolylinePoints}}" />
        {{/if}}
        {{!-- Data points --}}
        {{#each dailyTrend}}
        <circle class="trend-svg-dot{{#if isPeak}} is-peak{{/if}}{{#if isLatest}} is-latest{{/if}}" cx="{{svgX}}" cy="{{svgY}}" r="1.4" />
        {{/each}}
      </svg>
    </div>
    <div class="trend-footer">
      {{#each dailyTrend}}
      <span class="trend-xlbl{{#unless showDateLabel}} trend-xlbl--hidden{{/unless}}{{#if @last}} trend-xlbl--last{{/if}}">{{dateLabel}}</span>
      {{/each}}
    </div>
    <div class="trend-peak-row">
      <span>{{@root.labels.peakLabel}}: {{dailyTrendPeak}}</span>
      <span>{{@root.labels.latestLabel}}: {{dailyTrendLatest}}</span>
    </div>
    {{#if trendSummary}}<p class="chart-summary">{{trendSummary}}</p>{{/if}}
  </div>
</div>
{{else}}
<p class="hbar__empty">—</p>
{{/if}}
