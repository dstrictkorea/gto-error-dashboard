{{!-- ═══════════════════════════════════════════════════════════════
  monthly-global.hbs — All-branch monthly dashboard (v2)

  Layout:
    Page 1: chrome · title-block · KPI strip · 4 chart rows · footer
    Page 2 (if data): chrome · clusters · matrix · branch table · footer
    Zero-data: 1 page empty state
═══════════════════════════════════════════════════════════════ --}}

{{!-- ── PAGE 1 ─────────────────────────────────────────────────── --}}
<section class="page">
  <header class="page-chrome">
    <span class="brand-mark">d'strict · GTO</span>
    <span class="meta">
      <span>{{labels.reportTypeTitle}}</span>
      <span>·</span>
      <span>{{period}}</span>
      <span>·</span>
      <span>{{#if scope}}{{scope}}{{else}}{{labels.allBranches}}{{/if}}</span>
    </span>
    <span class="meta"><span>{{labels.page}} 1</span></span>
  </header>

  {{!-- Title Block --}}
  {{> title-block}}

  {{!-- KPI Strip --}}
  {{> kpi-strip}}

  {{#if hasData}}

  {{!-- Narrative (compact, 1–2 sentences) --}}
  <p class="narrative-compact">{{narrative.s1}} {{narrative.s2}}</p>

  {{!-- Row 1: Incidents by Branch (8) + Daily Trend (4) --}}
  <div class="dash-row">
    <div class="dash-col--8">
      <div class="chart-card">
        <div class="chart-title">{{labels.incidentsByBranch}}</div>
        {{> hbar items=branchSorted}}
        {{#if branchSummary}}<p class="chart-summary">{{branchSummary}}</p>{{/if}}
      </div>
    </div>
    <div class="dash-col--4">
      <div class="chart-card">
        <div class="chart-title">{{labels.dailyTrendTitle}}</div>
        {{> trend-daily}}
      </div>
    </div>
  </div>

  {{!-- Row 2: Zone (6) + Category (6) --}}
  <div class="dash-row">
    <div class="dash-col--6">
      <div class="chart-card">
        <div class="chart-title">{{labels.zoneDistribution}}</div>
        {{> hbar items=zoneSorted}}
        {{#if zoneSummary}}<p class="chart-summary">{{zoneSummary}}</p>{{/if}}
      </div>
    </div>
    <div class="dash-col--6">
      <div class="chart-card">
        <div class="chart-title">{{labels.categoryDistribution}}{{#if catDominant}} ★{{/if}}</div>
        {{> stacked-bar items=categorySorted summary=catSummary}}
      </div>
    </div>
  </div>

  {{!-- Row 3: Resolve Time (6) + Action Type Donut (6) --}}
  <div class="dash-row">
    <div class="dash-col--6">
      <div class="chart-card">
        <div class="chart-title">{{labels.resolveTimeDist}}</div>
        {{> stacked-bar items=timeTakenBuckets summary=resolveSummary}}
      </div>
    </div>
    <div class="dash-col--6">
      <div class="chart-card">
        <div class="chart-title">{{labels.actionTypeDist}}</div>
        {{> donut}}
      </div>
    </div>
  </div>

  {{!-- Row 4: Reported Difficulty (6) + Recommendations (6) --}}
  <div class="dash-row">
    <div class="dash-col--6">
      <div class="chart-card">
        <div class="chart-title">{{labels.reportedDifficulty}}</div>
        {{> difficulty-strip}}
        {{#if diffSummary}}<p class="chart-summary">{{diffSummary}}</p>{{/if}}
      </div>
    </div>
    <div class="dash-col--6">
      <div class="chart-card">
        <div class="chart-title">{{#if recommendations.length}}{{labels.recommendations}}{{else}}{{labels.observations}}{{/if}}</div>
        {{> evidence}}
      </div>
    </div>
  </div>

  {{else}}
  {{!-- Zero-data state --}}
  <div class="zero-data-card">
    <p>{{labels.noData}}</p>
  </div>
  {{/if}}

  <footer class="page-footer">
    <span>{{generated}}</span>
    <span>{{labels.page}} 1</span>
  </footer>
</section>

{{!-- ── PAGE 2 (clusters · matrix · branch table) ─────────────────── --}}
{{#if hasData}}
{{#if repeatedIssueClusters.length}}
<section class="page">
  <header class="page-chrome">
    <span class="brand-mark">d'strict · GTO</span>
    <span class="meta">
      <span>{{labels.reportTypeTitle}}</span>
      <span>·</span>
      <span>{{period}}</span>
    </span>
    <span class="meta"><span>{{labels.page}} 2</span></span>
  </header>

  {{!-- Issue Cluster Cards (12) --}}
  <div class="dash-row">
    <div class="dash-col--12">
      <div class="chart-card chart-card--clusters">
        <div class="chart-title">{{labels.issueClusters}}</div>
        {{> cluster-cards}}
        {{#if issueSummary}}<p class="chart-summary">{{issueSummary}}</p>{{/if}}
      </div>
    </div>
  </div>

  {{!-- Zone × Category Matrix (6) + Branch Comparison (6) --}}
  <div class="dash-row">
    <div class="dash-col--6">
      <div class="chart-card">
        <div class="chart-title">{{labels.zoneCategoryMatrix}}</div>
        {{> zone-matrix}}
      </div>
    </div>
    <div class="dash-col--6">
      <div class="chart-card">
        <div class="chart-title">{{labels.branchComparison}}</div>
        {{> branch-table}}
      </div>
    </div>
  </div>

  <footer class="page-footer">
    <span>{{generated}}</span>
    <span>{{labels.page}} 2</span>
  </footer>
</section>
{{/if}}
{{/if}}
